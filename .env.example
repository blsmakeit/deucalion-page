# ==========================================
# Configurações do Servidor
# ==========================================
PORT=3000

# ==========================================
# Inteligência Artificial (Claude)
# ==========================================
# A tua chave da API da Anthropic (começa com sk-ant-...)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==========================================
# Configurações de Email (Resend SMTP)
# ==========================================
# Dados de acesso ao servidor SMTP do Resend
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
# A tua API Key do Resend (começa com re_...)
SMTP_PASS=your_resend_api_key_here

# ==========================================
# Destinatários dos Formulários de Contacto
# ==========================================
# Os emails que vão RECEBER as mensagens enviadas pelos utilizadores
CONTACT_EMAIL_MAKEIT=contact@make-it.tech
CONTACT_EMAIL_DEUCALION=hello.deucalion@acnca.pt
CONTACT_EMAIL_COTEC=geral@cotec.pt.